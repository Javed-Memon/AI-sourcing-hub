};

const CSS = `
@import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  transition: background 0.3s ease, color 0.3s ease;
}

:root {
  --font-serif: 'Instrument Serif', Georgia, serif;
  --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
  --teal: #0891B2; --teal2: #06B6D4;
  --teal-faint: rgba(8,145,178,0.10); --teal-faint2: rgba(8,145,178,0.18);
  --violet: #6366F1; --violet2: #818CF8; --violet-faint: rgba(99,102,241,0.10);
  --amber: #D97706; --amber-faint: rgba(217,119,6,0.10);
  --green: #059669; --green-faint: rgba(5,150,105,0.10);
  --red: #DC2626; --red-faint: rgba(220,38,38,0.10);
}

::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--glass3); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--border2); }

@keyframes fadeUp   { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
@keyframes fadeIn   { from { opacity:0; } to { opacity:1; } }
@keyframes spin     { from { transform:rotate(0deg); } to { transform:rotate(360deg); } }
@keyframes pulse    { 0%,100%{opacity:1} 50%{opacity:.45} }
@keyframes shimmer  { from{transform:translateX(-100%)} to{transform:translateX(200%)} }
@keyframes slideInR { from{transform:translateX(24px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes popIn    { 0%{transform:scale(.92);opacity:0} 100%{transform:scale(1);opacity:1} }

.card {
  background: var(--card-bg);
  border: 1px solid var(--card-border);
  border-radius: 12px;
  transition: border-color .2s, box-shadow .2s, transform .2s;
}
.card:hover {
  border-color: rgba(8,145,178,.35);
  box-shadow: 0 6px 28px var(--shadow2);
}
.card-lift:hover { transform: translateY(-2px); }

.btn-primary {
  background: linear-gradient(135deg, var(--teal) 0%, var(--violet) 100%);
  color: #fff; border: none; cursor: pointer;
  font-family: var(--font-body); font-weight: 600;
  border-radius: 8px; transition: all .2s;
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
}
.btn-primary:hover { filter: brightness(1.08); box-shadow: 0 4px 16px rgba(8,145,178,.3); }
.btn-primary:disabled { opacity:.4; cursor:default; filter:none; box-shadow:none; }

.btn-secondary {
  background: var(--glass); color: var(--text2);
  border: 1px solid var(--border); cursor: pointer;
  font-family: var(--font-body); font-weight: 500;
  border-radius: 8px; transition: all .2s;
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
}
.btn-secondary:hover { background: var(--glass2); color: var(--text); border-color: var(--border2); }

.btn-ghost {
  background: transparent; color: var(--text3);
  border: none; cursor: pointer;
  font-family: var(--font-body); font-weight: 500;
  border-radius: 8px; transition: all .2s;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-ghost:hover { color: var(--text); background: var(--glass); }

.inp {
  background: var(--glass); border: 1px solid var(--border);
  color: var(--text); font-family: var(--font-body); font-size: 14px;
  border-radius: 8px; padding: 10px 14px; outline: none; width: 100%;
  transition: border-color .2s, background .2s;
}
.inp:focus { border-color: var(--teal); background: var(--teal-faint); }
.inp::placeholder { color: var(--text3); }
select.inp option { background: var(--bg3); color: var(--text); }

.tab-btn {
  flex: 1; padding: 11px 4px; border: none; cursor: pointer;
  font-family: var(--font-body); font-size: 13px; font-weight: 600;
  transition: all .15s; background: transparent;
  border-bottom: 2px solid transparent;
}

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 14px; border-radius: 8px; cursor: pointer;
  transition: all .15s; font-family: var(--font-body); font-size: 13px;
  font-weight: 500; color: var(--text3); border: none; background: transparent;
  width: 100%; text-align: left;
}
.nav-item:hover { background: var(--glass2); color: var(--text2); }
.nav-item.active {
  background: var(--teal-faint2); color: var(--teal);
  border-left: 2px solid var(--teal);
}

.pbar { height: 6px; background: var(--glass2); border-radius: 3px; overflow: hidden; }
.pbar-fill { height: 100%; border-radius: 3px; transition: width .7s ease; }

.chip {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 9px; border-radius: 20px;
  font-size: 11px; font-weight: 600; letter-spacing: .2px;
  font-family: var(--font-body);
}

.section-label {
  font-family: var(--font-body); font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: .9px; color: var(--text3);
}

.theme-transition * { transition: background-color .3s ease, border-color .3s ease, color .3s ease !important; }
`;

